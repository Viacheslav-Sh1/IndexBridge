# ==================== ОСНОВНЫЕ ====================

# API ключ для доступа к прокси (обязательно)
PROXY_API_KEY=your-secret-key-here

# Часовой пояс
TZ=Europe/Kyiv

# Порт на котором работает прокси
PORT=8000

# Имя объединённого эндпоинта (отдаёт результаты со всех провайдеров)
# По умолчанию: all
COMBINED_NAME=all

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
# DEBUG   - всё включая http-запросы и фильтрацию
# INFO    - старт, поиски, ошибки (по умолчанию)
# WARNING - только ошибки
# ERROR   - только критические ошибки
LOG_LEVEL=INFO

# ==================== ПРОВАЙДЕРЫ ====================
# ВАЖНО: Удалите неиспользуемых провайдеров.
# Если в NAMES указан провайдер, для него должны быть заданы URL и API_KEY.
# Имена чувствительны к регистру: jac и JAC — разные провайдеры.
# Единый список имён провайдеров через запятую
NAMES=jred,jac,pr

# Для Windows/Mac: host.docker.internal
# Для Linux: localhost или IP хоста
# Jackett (в том числе Jacred как Jackett-совместимый сервер)
JACKETT_jred_URL=https://remote.example.com
JACKETT_jred_API_KEY=key-jred

JACKETT_jac_URL=http://localhost:9117
JACKETT_jac_API_KEY=your-jackett-key

# Prowlarr
PROWLARR_pr_URL=http://host.docker.internal:9696
PROWLARR_pr_API_KEY=your-prowlarr-key

# Приоритет провайдеров при дедупликации (чем левее, тем выше приоритет)
# Если не задан — выбирается по количеству сидеров
# PROVIDER_PRIORITY=jac,jred,pr

# ==================== ПРОИЗВОДИТЕЛЬНОСТЬ ====================

# Максимальное время ожидания ответа от провайдера (секунд)
# По умолчанию: 15
PROVIDER_TIMEOUT=15

# Время жизни кеша пустых запросов RSS (секунд)
# По умолчанию: 300 (5 минут)
RSS_CACHE_TTL=300

# Количество ошибок подряд для отключения провайдера
# По умолчанию: 3
CB_MAX_FAILS=3

# Время отключения провайдера (секунд)
# По умолчанию: 300 (5 минут)
CB_TIMEOUT=300

# ==================== БЕЗОПАСНОСТЬ ====================

# Включить ограничение запросов
RATE_LIMIT_ENABLED=true

# Максимум запросов от одного IP за окно
RATE_LIMIT_REQUESTS=60

# Окно в секундах
RATE_LIMIT_WINDOW=60

# ==================== ФИЛЬТРЫ ====================

# Минимальное количество сидеров (0 = без ограничения)
FILTER_MIN_SEEDERS=1

# Максимальное количество сидеров (0 = без ограничения)
FILTER_MAX_SEEDERS=0

# Минимальное количество пиров (0 = без ограничения)
FILTER_MIN_PEERS=0

# Запрещённые языки через запятую: rus,ukr,eng (пусто = все разрешены)
FILTER_LANGUAGES=

# Запрещённые студии озвучки через запятую (пусто = все разрешены)
# Пример: AVO,TV,Одноголосый
FILTER_VOICES=

# Запрещённые слова в заголовке через запятую (пусто = без фильтра)
# Пример: camrip,ts,scr,телевизионная
FILTER_BLACKLIST_TITLES=

# Минимальное качество видео: 480, 720, 1080, 1440, 2160
FILTER_QUALITY_MIN=0

# Максимальное качество видео
FILTER_QUALITY_MAX=9999